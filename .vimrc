syntax on
set number
set relativenumber
set showmode
set cursorline
set shiftwidth=4
set tabstop=4
set expandtab
set scrolloff=10
set ignorecase
set smartcase
set hlsearch
set incsearch
set laststatus=2
set mouse=a

set omnifunc=syntaxcomplete#Complete
set completeopt=fuzzy,menuone,noinsert,noselect,popup

set background=light
colorscheme default
