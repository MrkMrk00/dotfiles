syntax on
let g:mapleader = ' '
let g:maploacalleader = ' '
set number
set relativenumber
set showmode
set cursorline
set shiftwidth=4
set tabstop=4
set expandtab
set scrolloff=10
set ignorecase
set smartcase
set hlsearch
set incsearch
set laststatus=2
set spell
set mouse=a

set omnifunc=syntaxcomplete#Complete
set completeopt=fuzzy,menuone,noinsert,noselect,popup
set complete=o,.,w

colorscheme desert
