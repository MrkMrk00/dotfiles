#!/usr/bin/env bash

set -euo pipefail

machine_name="$1"
if [[ -z "$machine_name" ]]; then
    echo 'please provide the machine name' >&2
fi

ssh_config_path=$(limactl ls --format='{{.SSHConfigFile}}' "$machine_name")

kitten ssh -F "$ssh_config_path" "lima-$machine_name" rm "/run/user/$(id -u)/gnupg/S.gpg-agent"
kitten ssh -F "$ssh_config_path" -O exit "lima-$machine_name"
